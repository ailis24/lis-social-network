{
  "$schema": "https://amvera.cloud/schema.json",
  "meta": {
    "name": "lis-social-network",
    "environment": "nodejs"
  },
  "build": {
    "prebuild": "npm ci --only=production"
  },
  "run": {
    "command": "node server.js",
    "persistent": {
      "storage": "/app/lis_users.db",
      "mountPath": "/app"
    }
  },
  "env": {
    "NODE_ENV": "production",
    "PORT": "3001",
    "API_PORT": "3001"
  }
}
